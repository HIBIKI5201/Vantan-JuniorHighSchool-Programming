---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const courses = (await getCollection("courses")).sort((a, b) => b.data.order - a.data.order);
const allLessons = await getCollection("lessons");
const baseUrl = import.meta.env.BASE_URL;

const dayAccentMap: Record<string, string> = {
	月曜日: "var(--day-mon)",
	火曜日: "var(--day-tue)",
	水曜日: "var(--day-wed)",
	木曜日: "var(--day-thu)",
	金曜日: "var(--day-fri)",
	単発: "var(--day-single)",
	"-": "var(--day-ref)",
};

function accentFor(dayOfWeek: string) {
	return dayAccentMap[dayOfWeek] ?? "var(--color-accent)";
}
---
<Layout>
	<h1>授業資料一覧</h1>
	<p>バンタン中等部で行っているプログラミング授業(Scratch)の資料です。コースを選んでください。</p>
	<div class="course-grid">
		{courses.map((course) => {
			const lessonCount = allLessons.filter((l) => l.data.course === course.slug).length;
			return (
				<a class="course-card" style={`--card-accent: ${accentFor(course.data.dayOfWeek)}`} href={`${baseUrl}courses/${course.slug}/`}>
					<div class="course-card-top">
						<span class="course-card-day">{course.data.dayOfWeek}</span>
						{course.data.status === "partial" && <span class="badge">🚧 一部準備中</span>}
					</div>
					<div class="course-card-title">{course.data.title}</div>
					<div class="course-card-meta">{course.data.period}</div>
					<div class="course-card-footer">
						{lessonCount > 0 ? `全${lessonCount}回` : "準備中"}
						<span class="course-card-arrow">→</span>
					</div>
				</a>
			);
		})}
	</div>
</Layout>
<style>
	.course-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
		gap: 1.1rem;
		margin-top: 2rem;
	}

	.course-card {
		position: relative;
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.3rem 1.3rem 1.1rem;
		text-decoration: none;
		color: var(--color-text);
		box-shadow: var(--shadow-sm);
		transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
		overflow: hidden;
	}

	.course-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 5px;
		background: var(--card-accent);
	}

	.course-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-lg);
		border-color: var(--card-accent);
	}

	.course-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-top: 0.3rem;
	}

	.course-card-day {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--card-accent);
	}

	.course-card-day::before {
		content: "";
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: var(--card-accent);
	}

	.course-card-title {
		font-weight: 700;
		font-size: 1.2rem;
		margin-top: 0.7rem;
	}

	.course-card-meta {
		color: var(--color-text-muted);
		font-size: 0.88rem;
		margin-top: 0.25rem;
	}

	.course-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 1.1rem;
		padding-top: 0.9rem;
		border-top: 1px solid var(--color-border);
		font-size: 0.82rem;
		color: var(--color-text-muted);
		font-weight: 500;
	}

	.course-card-arrow {
		color: var(--card-accent);
		font-weight: 700;
		transition: transform 0.18s ease;
	}

	.course-card:hover .course-card-arrow {
		transform: translateX(3px);
	}
</style>
