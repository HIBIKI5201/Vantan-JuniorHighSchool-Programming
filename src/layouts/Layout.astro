---
const { title = "バンタン中等部 プログラミング授業資料" } = Astro.props;
let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith("/")) baseUrl += "/";
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href={`${baseUrl}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={baseUrl}>
				<span class="brand-badge">🎮</span>
				<span class="brand-text">バンタン中等部<span class="brand-sub">プログラミング授業資料</span></span>
			</a>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>バンタン中等部 プログラミング授業</p>
		</footer>
	</body>
</html>
<style is:global>
	:root {
		color-scheme: light;

		--color-bg: #f7f5ef;
		--color-bg-gradient: radial-gradient(circle at 10% 0%, #eef2ff 0%, #f7f5ef 45%);
		--color-surface: #ffffff;
		--color-surface-2: #f4f1e8;
		--color-text: #2b2a27;
		--color-text-muted: #6f6d67;
		--color-border: #e7e2d3;

		--color-accent: #4f6df5;
		--color-accent-ink: #2c48d6;
		--color-accent-soft: #eaeeff;

		--color-callout-bg: linear-gradient(180deg, #fffaf0 0%, #fff6df 100%);
		--color-callout-border: #f0cf6d;
		--color-callout-icon-bg: #ffdd6b;

		--color-partial-bg: #fff1e6;
		--color-partial-border: #f3b27a;
		--color-partial-text: #a35a17;

		--color-missing-bg: #f6f4ee;
		--color-missing-border: #ddd6c2;
		--color-missing-text: #8a8574;

		--radius-sm: 10px;
		--radius-md: 16px;
		--radius-lg: 22px;

		--shadow-sm: 0 1px 2px rgba(30, 24, 10, 0.05);
		--shadow-md: 0 10px 24px -8px rgba(30, 24, 10, 0.14);
		--shadow-lg: 0 20px 48px -12px rgba(30, 24, 10, 0.22);

		--day-mon: #8f8f9a;
		--day-tue: #34b37e;
		--day-wed: #9b6fe0;
		--day-thu: #d18a34;
		--day-fri: #4f6df5;
		--day-single: #ef7d5c;
		--day-ref: #5a8a94;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			color-scheme: dark;

			--color-bg: #14151a;
			--color-bg-gradient: radial-gradient(circle at 10% 0%, #1c2036 0%, #14151a 45%);
			--color-surface: #1c1d24;
			--color-surface-2: #23252d;
			--color-text: #eae8e2;
			--color-text-muted: #9b9a93;
			--color-border: #302f36;

			--color-accent: #8fa4ff;
			--color-accent-ink: #b6c4ff;
			--color-accent-soft: rgba(143, 164, 255, 0.14);

			--color-callout-bg: linear-gradient(180deg, rgba(244, 207, 101, 0.14) 0%, rgba(244, 207, 101, 0.08) 100%);
			--color-callout-border: rgba(240, 207, 109, 0.45);
			--color-callout-icon-bg: #caa33c;

			--color-partial-bg: rgba(243, 178, 122, 0.14);
			--color-partial-border: rgba(243, 178, 122, 0.45);
			--color-partial-text: #f3b27a;

			--color-missing-bg: rgba(255, 255, 255, 0.04);
			--color-missing-border: rgba(255, 255, 255, 0.12);
			--color-missing-text: #9b9a93;

			--shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
			--shadow-md: 0 10px 24px -8px rgba(0, 0, 0, 0.5);
			--shadow-lg: 0 20px 48px -12px rgba(0, 0, 0, 0.6);
		}
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		font-family: "Zen Maru Gothic", "Hiragino Maru Gothic ProN", sans-serif;
		background: var(--color-bg-gradient), var(--color-bg);
		color: var(--color-text);
		line-height: 1.9;
		font-size: 16.5px;
		-webkit-font-smoothing: antialiased;
	}

	main {
		max-width: 780px;
		margin: 0 auto;
		padding: 2rem 1.25rem 5rem;
	}

	/* ---------- header / footer ---------- */

	.site-header {
		background: color-mix(in srgb, var(--color-surface) 88%, transparent);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--color-border);
		padding: 0.75rem 1.25rem;
		position: sticky;
		top: 0;
		z-index: 10;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: var(--color-text);
		text-decoration: none;
		max-width: 780px;
		margin: 0 auto;
	}

	.brand-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		border-radius: var(--radius-sm);
		background: var(--color-accent-soft);
		font-size: 1.15rem;
		flex-shrink: 0;
	}

	.brand-text {
		font-weight: 700;
		font-size: 1rem;
		line-height: 1.3;
		display: flex;
		flex-direction: column;
	}

	.brand-sub {
		font-weight: 500;
		font-size: 0.72rem;
		color: var(--color-text-muted);
	}

	.site-footer {
		text-align: center;
		color: var(--color-text-muted);
		font-size: 0.85rem;
		padding: 3rem 1rem 2.5rem;
	}

	/* ---------- typography ---------- */

	h1, h2, h3 {
		line-height: 1.5;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	h1 {
		font-size: 1.75rem;
		margin: 0.5rem 0 1.25rem;
		padding-bottom: 0.6rem;
		border-bottom: 3px solid var(--color-accent);
	}

	h2 {
		font-size: 1.3rem;
		margin: 2.75rem 0 1.1rem;
		padding: 0.15rem 0 0.15rem 0.75rem;
		border-left: 6px solid var(--color-accent);
	}

	h3 {
		font-size: 1.08rem;
		margin: 2rem 0 0.9rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	h3::before {
		content: "";
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 3px;
		background: var(--color-accent);
		flex-shrink: 0;
		transform: rotate(45deg);
	}

	p {
		margin: 0.9rem 0;
	}

	a {
		color: var(--color-accent-ink);
		text-decoration-color: color-mix(in srgb, var(--color-accent-ink) 40%, transparent);
		text-underline-offset: 0.15em;
	}

	a:hover {
		text-decoration-thickness: 2px;
	}

	strong {
		font-weight: 700;
	}

	code {
		background: var(--color-surface-2);
		border: 1px solid var(--color-border);
		padding: 0.1rem 0.4rem;
		border-radius: 6px;
		font-size: 0.9em;
	}

	hr {
		border: none;
		border-top: 1px dashed var(--color-border);
		margin: 2.5rem 0;
	}

	/* ---------- images ---------- */

	img {
		max-width: 100%;
		display: block;
		margin: 1.4rem 0;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-sm);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	article img:hover {
		transform: scale(1.012);
		box-shadow: var(--shadow-md);
	}

	/* ---------- lists ---------- */

	ul, ol {
		padding-left: 0;
		margin: 1rem 0;
		list-style: none;
	}

	ul li, ol li {
		position: relative;
		margin: 0.55rem 0;
		padding-left: 2rem;
	}

	ul li::before {
		content: "";
		position: absolute;
		left: 0.15rem;
		top: 0.65em;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--color-accent);
	}

	ol {
		counter-reset: step;
	}

	ol li {
		counter-increment: step;
	}

	ol li::before {
		content: counter(step);
		position: absolute;
		left: 0;
		top: 0;
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 50%;
		background: var(--color-accent-soft);
		color: var(--color-accent-ink);
		font-weight: 700;
		font-size: 0.8rem;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	/* 目標セクションなど、見出し直下の最初のリストは少し詰めて自然に見せる */
	h1 + ul, h1 + ol, h2 + ul, h2 + ol, h3 + ul, h3 + ol {
		margin-top: 0.5rem;
	}

	/* ---------- callout (aside) ---------- */

	aside {
		position: relative;
		background: var(--color-callout-bg);
		border: 1px solid var(--color-callout-border);
		border-radius: var(--radius-lg);
		padding: 1.6rem 1.4rem 1.3rem 1.6rem;
		margin: 1.6rem 0;
		box-shadow: var(--shadow-sm);
	}

	aside p {
		margin: 0.65rem 0;
	}

	aside p.aside-icon {
		position: absolute;
		top: -1rem;
		left: 1.1rem;
		width: 2.5rem;
		height: 2.5rem;
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.3rem;
		background: var(--color-callout-icon-bg);
		border-radius: 50%;
		box-shadow: var(--shadow-sm);
		border: 1px solid var(--color-callout-border);
	}

	aside p.aside-icon + p {
		margin-top: 0.6rem;
	}

	aside p:last-child {
		margin-bottom: 0;
	}

	/* partial(準備中)ノート用のaside(ページ最上部)は少し落ち着いた色にする */
	main > aside:first-of-type {
		--color-callout-bg: var(--color-partial-bg);
		--color-callout-border: var(--color-partial-border);
		--color-callout-icon-bg: color-mix(in srgb, var(--color-partial-border) 60%, white);
	}

	/* ---------- 画像が見つからない時のプレースホルダー( *[...]* が em になる ) ---------- */

	article em {
		display: block;
		font-style: normal;
		color: var(--color-missing-text);
		background: var(--color-missing-bg);
		border: 1px dashed var(--color-missing-border);
		border-radius: var(--radius-sm);
		padding: 0.9rem 1.1rem;
		margin: 1.2rem 0;
		font-size: 0.88rem;
	}

	/* ---------- 見本プロジェクト・フォームなど、単独リンクの段落をボタン風にする ---------- */

	article p:has(> a:only-child):where(:not(:has(> a[href*="/courses/"]))) {
		margin: 1.4rem 0;
	}

	article p:has(> a:only-child):where(:not(:has(> a[href*="/courses/"]))) > a {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 0.9rem 1.15rem;
		font-weight: 700;
		text-decoration: none;
		box-shadow: var(--shadow-sm);
		transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
		word-break: break-all;
	}

	article p:has(> a:only-child):where(:not(:has(> a[href*="/courses/"]))) > a:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
		border-color: var(--color-accent);
	}

	article p:has(> a:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::before {
		content: "▶";
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		background: var(--color-accent-soft);
		color: var(--color-accent-ink);
		font-size: 0.7rem;
		flex-shrink: 0;
	}

	article p:has(> a[href*="scratch.mit.edu"]:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::before {
		content: "🐱";
		font-size: 1rem;
	}

	article p:has(> a[href*="scratch.mit.edu"]:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::after {
		content: "Scratchで見本を開く";
		margin-left: auto;
		font-size: 0.72rem;
		font-weight: 500;
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	article p:has(> a[href*="forms.gle"]:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::before,
	article p:has(> a[href*="docs.google.com/forms"]:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::before {
		content: "📝";
		font-size: 1rem;
	}

	article p:has(> a[href*="forms.gle"]:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::after,
	article p:has(> a[href*="docs.google.com/forms"]:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::after {
		content: "フォームに回答する";
		margin-left: auto;
		font-size: 0.72rem;
		font-weight: 500;
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	@media (max-width: 480px) {
		article p:has(> a:only-child):where(:not(:has(> a[href*="/courses/"]))) > a::after {
			display: none;
		}
	}

	/* ---------- Scratch wikiの用語ページへのリンク(文中に埋め込まれる、独立した段落ではない) ---------- */

	article a[href*="/courses/scratch-wiki/"] {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		background: var(--color-accent-soft);
		color: var(--color-accent-ink);
		padding: 0.1rem 0.65rem 0.1rem 0.5rem;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
		font-size: 0.92em;
		vertical-align: middle;
		transition: background 0.15s ease, color 0.15s ease;
	}

	article a[href*="/courses/scratch-wiki/"]::before {
		content: "📖";
		font-size: 0.85em;
	}

	article a[href*="/courses/scratch-wiki/"]:hover {
		background: var(--color-accent);
		color: white;
	}

	/* ---------- 汎用ユーティリティ ---------- */

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.74rem;
		font-weight: 700;
		background: var(--color-partial-bg);
		color: var(--color-partial-text);
		border: 1px solid var(--color-partial-border);
		border-radius: 999px;
		padding: 0.2rem 0.7rem;
	}

	@media (max-width: 600px) {
		main {
			padding: 1.5rem 1rem 4rem;
		}
		h1 {
			font-size: 1.45rem;
		}
		h2 {
			font-size: 1.15rem;
		}
	}
</style>
